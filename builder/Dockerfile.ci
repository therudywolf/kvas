# Light image for CI: build .ipk (pack-only) and run tests. Alpine — быстрая сборка, совместимый ar для opkg.
FROM alpine:3.19

RUN apk add --no-cache \
    binutils \
    bash \
    findutils \
    gzip \
    tar \
    sed \
    coreutils

WORKDIR /workspace
ENTRYPOINT ["./scripts/ci.sh"]
CMD ["--quick"]
