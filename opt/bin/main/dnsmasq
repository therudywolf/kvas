#!/bin/sh

#------------------------------------------------------------------------------
#
#	ПАКЕТ FRT
#
#------------------------------------------------------------------------------
#
#	Данный файл служит для формирования из записей frt.list
#	специальных записей вида "ipset=/хост/FRT_LIST"
# 	в /opt/etc/dnsmasq.d/frt.dnsmasq.
#
# -----------------------------------------------------------------------------
#	Разработчик: mail@zeleza.ru
#	Дата создания: 21/05/2022
#	Лицензия: Apache License 2.0
# -----------------------------------------------------------------------------

# если делать этот файл автономно запускаемым, то нужна
#. /opt/apps/frt/bin/libs/main

logger -t 'FRT' 'Обновление доменной конфигурации DNSMasq'

IPSET_TABLE_NAME=FRT_LIST
ipset_file=/opt/etc/dnsmasq.d/frt.dnsmasq
host_list=/opt/etc/frt.list
LOCALHOST_IP=127.0.0.1

# обнуляем защищенный список
> "${ipset_file}"

[ ! -f "${host_list}" ] && exit 0

while read -r line || [ -n "${line}" ]; do
  # удаляем из строки комментарии - все что встречается после символа # и сам символ
  line=$(echo "${line}" | sed 's/#.*$//g' | tr -s ' ')
  [ -z "${line}" ] && continue
  case "${line}" in \#*) continue;; esac
  echo "${line}" | grep -Eq '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' && continue
  host=$(echo "${line}" | sed 's/\*//g;')
  echo "ipset=/${host}/${IPSET_TABLE_NAME}" >> "${ipset_file}"
done < "${host_list}"

num_recs_hosts_list=$(grep -E -v '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' "${host_list}" | grep -c . 2>/dev/null || echo 0)
num_recs_dnsmasq_list=$(grep -c ipset "${ipset_file}" 2>/dev/null || echo 0)
[ "${num_recs_hosts_list}" -gt 1 ] && [ "${num_recs_hosts_list}" = "${num_recs_dnsmasq_list}" ]
