# если делать этот файл автономно запускаемым, то нужна
#. /opt/apps/frt/bin/libs/main

HOST_LIST=/opt/etc/frt.list
IPSET_TABLE_NAME=FRT_LIST
IP_FILTER='[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}'
REGEXP_IP_OR_RANGE="${IP_FILTER}|${IP_FILTER}-${IP_FILTER}|${IP_FILTER}/[0-9]{1,2}"

log_warning 'Начат переобход доменов из списка'

# проверяем доступность сети (порт dnsmasq 9753 по умолчанию; при вызове из frt конфиг уже загружен)
DNS_PORT="${DNS_PORT:-9753}"
until ADDRS=$(kdig +short ya.ru @127.0.0.1:${DNS_PORT}) && [ -n "${ADDRS}" ] > /dev/null 2>&1; do sleep 5; done

count=0
while read -r line || [ -n "${line}" ]; do
	# пропускаем строки c минусами; пустые; комментарии
	case "${line}" in -*) continue;; '') continue;; \#*) continue;; esac

	# удаляем из строки комментарии - все что встречается после символа # и сам символ
	# удаляем *
	host=$(echo "${line}" | sed 's/#.*$//g' | tr -s ' ' | sed 's/\*//')

	count=$((count + 1))
	if [ "$(( ${count} % 50 ))" -eq 0 ]; then
		echo -n '.'
	fi

	# если строка IP, диапазон или маска
	if echo "${host}" | grep -qE -- "${REGEXP_IP_OR_RANGE}"; then
		continue
	fi

	ipset__fill_by_domain "${host}"
done < "${HOST_LIST}"
